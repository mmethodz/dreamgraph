# DreamGraph Engine Configuration Template
# Copy or instantiate per instance. Values here override global environment variables.
# Leave secrets blank until you intentionally configure them.

# --- LLM provider ----------------------------------------------------
# DREAMGRAPH_LLM_PROVIDER=ollama
# DREAMGRAPH_LLM_URL=http://localhost:11434
# DREAMGRAPH_LLM_API_KEY=

# --- Dreamer ---------------------------------------------------------
# DREAMGRAPH_LLM_DREAMER_MODEL=qwen3:8b
# DREAMGRAPH_LLM_DREAMER_TEMPERATURE=0.9
# DREAMGRAPH_LLM_DREAMER_MAX_TOKENS=4096

# --- Normalizer ------------------------------------------------------
# DREAMGRAPH_LLM_NORMALIZER_MODEL=qwen3:8b
# DREAMGRAPH_LLM_NORMALIZER_TEMPERATURE=0.1
# DREAMGRAPH_LLM_NORMALIZER_MAX_TOKENS=1024

# --- Database --------------------------------------------------------
# PostgreSQL connection string used by database schema/query tools.
# Stored here for per-instance persistence when set from the dashboard.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
