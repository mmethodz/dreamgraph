# DreamGraph Engine Configuration — Ollama preset
# Per-instance environment settings. Uncomment and edit as needed.
# Values here override global environment variables.
#
# Provider: ollama (local) | lmstudio (local) | openai (API) | anthropic (Claude API) | sampling (MCP client) | none

# --- Ollama (local model server, default port 11434) ---
DREAMGRAPH_LLM_PROVIDER=ollama
DREAMGRAPH_LLM_URL=http://localhost:11434
DREAMGRAPH_LLM_MODEL=qwen3:8b

# --- Optional: LM Studio (commented preset for symmetry) ---
# DREAMGRAPH_LLM_PROVIDER=lmstudio
# DREAMGRAPH_LLM_URL=http://localhost:1234/v1
# DREAMGRAPH_LLM_API_KEY=lm-studio
# DREAMGRAPH_LLM_MODEL=<model-id-from-LM-Studio-UI>

# Base tuning
# DREAMGRAPH_LLM_TEMPERATURE=0.7
# DREAMGRAPH_LLM_MAX_TOKENS=2048

# Dreamer — creative dream cycle generation
# DREAMGRAPH_LLM_DREAMER_TEMPERATURE=0.9
# DREAMGRAPH_LLM_DREAMER_MAX_TOKENS=10240

# Normalizer — validation / truth-filter pass
# DREAMGRAPH_LLM_NORMALIZER_TEMPERATURE=0.1
# DREAMGRAPH_LLM_NORMALIZER_MAX_TOKENS=4096
